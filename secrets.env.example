# secrets.env.example — COMMIT THIS FILE (placeholder values only)
# On the VPS: cp secrets.env.example secrets.env && chmod 600 secrets.env
# Fill in real values then: docker compose up -d

# Polymarket CLOB API credentials (three-part auth, not two)
# Generate via: python scripts/create_api_key.py
POLY_API_KEY=your_poly_api_key_here
POLY_API_SECRET=your_poly_api_secret_here
POLY_API_PASSPHRASE=your_poly_api_passphrase_here

# Non-custodial EOA wallet private key (for CLOB message signing only)
# Generate: python -c "from eth_account import Account; a = Account.create(); print(a.key.hex())"
WALLET_PRIVATE_KEY=0x_your_64_hex_char_private_key_here

# Alchemy Polygon PoS RPC endpoints (API key embedded in URL path — never log these)
# Obtain from: Alchemy dashboard -> Apps -> View Key
POLYGON_RPC_HTTP=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_api_key
POLYGON_RPC_WS=wss://polygon-mainnet.g.alchemy.com/v2/your_alchemy_api_key

# Phase 4 notification slots (reserved now, unused until Phase 4)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here
